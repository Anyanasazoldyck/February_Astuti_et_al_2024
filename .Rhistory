library(readr)
markers <- read_csv("analysis/markers.csv")
View(markers)
topn <- marker %>%
filter(avg_log2FC > 1 & p_val_adj < 0.01) %>%
group_by(cluster) %>%
arrange(desc(avg_log2FC), .by_group = TRUE) %>%
slice_head(n = 5)
topn <- markers %>%
filter(avg_log2FC > 1 & p_val_adj < 0.01) %>%
group_by(cluster) %>%
arrange(desc(avg_log2FC), .by_group = TRUE) %>%
slice_head(n = 5)
View(topn)
write.csv(topn,"analysis/Topmarkers.csv")
